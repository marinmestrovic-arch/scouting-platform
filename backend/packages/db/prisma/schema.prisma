model RunRequest {
  id                String           @id @default(uuid()) @db.Uuid
  requestedByUserId String           @map("requested_by_user_id") @db.Uuid
  name              String
  query             String
  target            Int?
  campaignId        String?          @map("campaign_id") @db.Uuid
  client            String?
  market            String?
  campaignManagerUserId String?      @map("campaign_manager_user_id") @db.Uuid
  briefLink         String?          @map("brief_link")
  campaignName      String?          @map("campaign_name")
  month             RunMonth?
  year              Int?
  dealOwner         String?          @map("deal_owner")
  dealName          String?          @map("deal_name")
  pipeline          String?
  dealStage         String?          @map("deal_stage")
  currency          String?
  dealType          String?          @map("deal_type")
  activationType    String?          @map("activation_type")
  hubspotInfluencerType String?      @map("hubspot_influencer_type")
  hubspotInfluencerVertical String?  @map("hubspot_influencer_vertical")
  hubspotCountryRegion String?       @map("hubspot_country_region")
  hubspotLanguage   String?          @map("hubspot_language")
  status            RunRequestStatus @default(QUEUED)
  lastError         String?          @map("last_error") @db.Text
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  startedAt         DateTime?        @map("started_at")
  completedAt       DateTime?        @map("completed_at")
  requestedByUser   User             @relation("RunRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  campaign          Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignManagerUser User?          @relation("RunCampaignManager", fields: [campaignManagerUserId], references: [id], onDelete: SetNull)
  hubspotImportBatches HubspotImportBatch[]
  hubspotRowOverrides RunHubspotRowOverride[]
  results           RunResult[]

  @@index([requestedByUserId], map: "run_requests_requested_by_user_id_idx")
  @@index([requestedByUserId, createdAt], map: "run_requests_requested_by_user_id_created_at_idx")
  @@index([campaignId], map: "run_requests_campaign_id_idx")
  @@index([campaignManagerUserId], map: "run_requests_campaign_manager_user_id_idx")
  @@index([campaignManagerUserId, createdAt], map: "run_requests_campaign_manager_user_id_created_at_idx")
  @@index([client], map: "run_requests_client_idx")
  @@index([client, createdAt], map: "run_requests_client_created_at_idx")
  @@index([market], map: "run_requests_market_idx")
  @@index([market, createdAt], map: "run_requests_market_created_at_idx")
  @@index([status], map: "run_requests_status_idx")
  @@index([createdAt], map: "run_requests_created_at_idx")
  @@map("run_requests")
}

