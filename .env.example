DATABASE_URL="postgresql://scouting:scouting@localhost:5432/scouting_platform?schema=public"
DATABASE_URL_TEST="postgresql://scouting:scouting@localhost:5432/scouting_platform_test?schema=public"
PG_BOSS_SCHEMA="pgboss"
AUTH_SECRET="local-dev-auth-secret-32-chars!!"
APP_ENCRYPTION_KEY="12345678901234567890123456789012"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-nano"
# HYPEAUDITOR_API_KEY uses the current HypeAuditor auth format: <auth_id>:<auth_token>
HYPEAUDITOR_API_KEY=""
INITIAL_ADMIN_YOUTUBE_API_KEY=""

# HubSpot Integration V2. Keep every feature flag false until the read-only
# connection health check passes. HUBSPOT_ACCESS_TOKEN is the preferred private
# app token; HUBSPOT_API_KEY is a deprecated compatibility fallback only.
HUBSPOT_ACCESS_TOKEN=""
HUBSPOT_API_KEY=""
HUBSPOT_BASE_URL="https://api.hubapi.com"
HUBSPOT_PORTAL_ID=""
# Numeric HubSpot application ID from the app settings. This is distinct from
# the OAuth client ID and is used to validate signed UI-extension context.
HUBSPOT_APP_ID=""
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""
HUBSPOT_DIRECT_SYNC_ENABLED="false"
HUBSPOT_WEBHOOKS_ENABLED="false"
HUBSPOT_WEBHOOK_JOURNAL_ENABLED="false"
HUBSPOT_UI_EXTENSIONS_ENABLED="false"

# These two internal names must be manually provisioned as unique properties in
# HubSpot before direct sync is enabled. The application never creates them.
HUBSPOT_CONTACT_UNIQUE_ID_PROPERTY="atlas_contact_id"
HUBSPOT_CONTACT_WORKED_WITH_PROPERTY="worked_with"
HUBSPOT_DEAL_UNIQUE_ID_PROPERTY="atlas_run_id"

# Portal-specific custom object and property internal names. Leave optional
# mappings empty when the property is not present in the portal. Association
# definitions are discovered and persisted; the numeric values are explicit
# directional fallbacks for portals with multiple plausible definitions.
HUBSPOT_CLIENT_OBJECT_TYPE=""
HUBSPOT_CAMPAIGN_OBJECT_TYPE=""
HUBSPOT_ACTIVATION_OBJECT_TYPE=""
HUBSPOT_DEAL_CAMPAIGN_ASSOCIATION_TYPE_ID=""
HUBSPOT_DEAL_CLIENT_ASSOCIATION_TYPE_ID=""
HUBSPOT_CLIENT_NAME_PROPERTY=""
HUBSPOT_CLIENT_DOMAIN_PROPERTY=""
HUBSPOT_CLIENT_COUNTRY_REGION_PROPERTY=""
HUBSPOT_CLIENT_CITY_PROPERTY=""
HUBSPOT_CLIENT_ACTIVE_PROPERTY=""
HUBSPOT_CAMPAIGN_NAME_PROPERTY=""
HUBSPOT_CAMPAIGN_CLIENT_OBJECT_ID_PROPERTY=""
HUBSPOT_CAMPAIGN_CLIENT_ASSOCIATION_TYPE_ID=""
HUBSPOT_CAMPAIGN_MARKET_PROPERTY=""
HUBSPOT_CAMPAIGN_BRIEF_LINK_PROPERTY=""
HUBSPOT_CAMPAIGN_MONTH_PROPERTY=""
HUBSPOT_CAMPAIGN_YEAR_PROPERTY=""
HUBSPOT_CAMPAIGN_STATUS_PROPERTY=""
HUBSPOT_CAMPAIGN_ACTIVE_PROPERTY=""
HUBSPOT_ACTIVATION_NAME_PROPERTY="activation_name"
HUBSPOT_ACTIVATION_TYPE_PROPERTY="activation_type"
HUBSPOT_ACTIVATION_URL_PROPERTY="activation_url"
HUBSPOT_ACTIVATION_PUBLICATION_DATE_PROPERTY="publication_date"
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Google Sheets exports use domain-wide delegation: the service account
# impersonates the signed-in user so Sheets evaluates permissions against
# that user. The service account's OAuth client ID must be authorized in
# admin.google.com → Security → API controls → Manage Domain Wide Delegation
# with the https://www.googleapis.com/auth/spreadsheets scope. Without that
# authorization every export fails with a 401 from Google's token endpoint.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
LOG_LEVEL="info"
WORKER_RUNS_DISCOVER_CONCURRENCY="1"
WORKER_CHANNELS_ENRICH_LLM_CONCURRENCY="2"
WORKER_CHANNELS_ENRICH_HYPEAUDITOR_CONCURRENCY="1"
WORKER_IMPORTS_CSV_PROCESS_CONCURRENCY="1"
WORKER_EXPORTS_CSV_GENERATE_CONCURRENCY="1"
WORKER_HUBSPOT_PREVIEW_ENRICH_CONCURRENCY="1"
WORKER_HUBSPOT_IMPORT_BATCH_CONCURRENCY="1"
WORKER_HUBSPOT_PUSH_BATCH_CONCURRENCY="1"
WORKER_HUBSPOT_HEALTH_CHECK_CONCURRENCY="1"
WORKER_HUBSPOT_OBJECT_SYNC_SCHEDULE_CONCURRENCY="1"
WORKER_HUBSPOT_OBJECT_SYNC_CONCURRENCY="1"
WORKER_HUBSPOT_WEBHOOK_CONCURRENCY="2"
WORKER_CONTINUOUS_ENRICHMENT_ENABLED="true"
WORKER_CONTINUOUS_ENRICHMENT_INTERVAL_MS="60000"
WORKER_CONTINUOUS_ENRICHMENT_INITIAL_DELAY_MS="5000"
WORKER_CONTINUOUS_ENRICHMENT_BATCH_SIZE="5"
WORKER_CONTINUOUS_ENRICHMENT_AI_STALE_AFTER_DAYS="365"
WORKER_CONTINUOUS_ENRICHMENT_YOUTUBE_STALE_AFTER_DAYS="30"
WORKER_CONTINUOUS_ENRICHMENT_MAX_RETRY_COUNT="5"
WORKER_CONTINUOUS_ENRICHMENT_PROCESSING_TIMEOUT_MS="1800000"
WORKER_CONTINUOUS_ENRICHMENT_QUEUED_TIMEOUT_MS="600000"
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="StrongAdminPassword123"
INITIAL_ADMIN_NAME="Initial Admin"

# Slack incoming webhook for user feedback submissions (see Feedback page)
SLACK_FEEDBACK_WEBHOOK_URL=""
