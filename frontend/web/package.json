{
  "name": "@scouting-platform/web",
  "private": true,
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@scouting-platform/contracts": "workspace:*",
    "@scouting-platform/core": "workspace:*",
    "@scouting-platform/db": "workspace:*",
    "argon2": "^0.43.0",
    "next": "^15.2.2",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@prisma/client": "^7.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.2",
    "vitest": "^3.0.9"
  },
  "scripts": {
    "predev": "pnpm --filter @scouting-platform/db db:generate",
    "dev": "next dev --turbopack",
    "prebuild": "pnpm --filter @scouting-platform/db db:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests --fileParallelism=false --exclude 'e2e/**' --exclude auth.credentials.test.ts",
    "test:smoke": "playwright test -c playwright.config.ts",
    "typecheck": "next typegen && tsc --noEmit"
  }
}
